<!DOCTYPE html>
<html>
<head>
    <title><%= app.title %> - Drop Your App</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Poppins', sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            margin: 0;
            padding: 20px;
            min-height: 100vh;
        }

        .app-container {
            max-width: 1200px;
            margin: 0 auto;
            background: white;
            border-radius: 30px;
            overflow: hidden;
            box-shadow: 0 20px 60px rgba(0,0,0,0.2);
        }

        .app-header {
            background: linear-gradient(135deg, #f093fb, #f5576c);
            padding: 2rem;
            color: white;
        }

        .app-header h1 {
            font-size: 2rem;
            margin-bottom: 0.5rem;
        }

        .app-preview {
            background: #f5f5f5;
            padding: 2rem;
            text-align: center;
            border-bottom: 3px dashed #ddd;
            position: relative;
        }

        .preview-toolbar {
            display: flex;
            justify-content: flex-end;
            margin-bottom: 1rem;
        }

        .fullscreen-btn {
            background: #667eea;
            color: white;
            border: none;
            padding: 0.5rem 1rem;
            border-radius: 40px;
            cursor: pointer;
            font-weight: bold;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            transition: transform 0.2s;
        }

        .fullscreen-btn:hover {
            transform: scale(1.05);
            background: #764ba2;
        }

        .preview-frame {
            width: 100%;
            height: 600px;
            border: none;
            border-radius: 20px;
            background: white;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
            transition: all 0.3s;
        }

        /* Fullscreen mode for iframe container */
        .preview-frame:fullscreen {
            width: 100vw;
            height: 100vh;
            border-radius: 0;
        }

        .preview-frame:-webkit-full-screen {
            width: 100vw;
            height: 100vh;
            border-radius: 0;
        }

        .preview-error {
            background: #fff3cd;
            border: 2px dashed #ffc107;
            border-radius: 20px;
            padding: 3rem;
            text-align: center;
        }

        .preview-error h3 {
            color: #856404;
            margin-bottom: 1rem;
        }

        .app-info {
            padding: 2rem;
        }

        .vote-section {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin: 1.5rem 0;
            padding: 1rem;
            background: #f9f9f9;
            border-radius: 20px;
        }

        .vote-btn {
            background: #ff6b6b;
            padding: 0.7rem 1.5rem;
            font-size: 1.1rem;
            border: none;
            border-radius: 40px;
            cursor: pointer;
            transition: transform 0.2s;
            color: white;
            font-weight: bold;
        }

        .vote-btn:hover {
            transform: scale(1.05);
        }

        .vote-count {
            font-size: 1.5rem;
            font-weight: bold;
            color: #667eea;
        }

        .comments-section {
            background: #f9f9f9;
            padding: 2rem;
            border-radius: 20px;
            margin-top: 1rem;
        }

        .comment {
            background: white;
            padding: 1rem;
            margin: 0.5rem 0;
            border-radius: 15px;
            border-left: 4px solid #f5576c;
        }

        .comment strong {
            color: #667eea;
        }

        textarea {
            width: 100%;
            padding: 0.8rem;
            border: 2px solid #e0e0e0;
            border-radius: 15px;
            font-family: inherit;
        }

        button {
            background: linear-gradient(135deg, #667eea, #764ba2);
            color: white;
            border: none;
            padding: 0.7rem 1.5rem;
            border-radius: 40px;
            cursor: pointer;
            font-weight: bold;
            margin-top: 0.5rem;
        }

        .back-btn {
            display: inline-block;
            margin-top: 1rem;
            color: white;
            text-decoration: none;
            background: rgba(255,255,255,0.2);
            padding: 0.5rem 1rem;
            border-radius: 40px;
        }

        .delete-btn {
            background: #dc3545;
            margin-left: 1rem;
        }
    </style>
</head>
<body>
    <div class="app-container">
        <div class="app-header">
            <h1>🚀 <%= app.title %></h1>
            <p>by <strong><%= app.username %></strong></p>
            <p><small>📅 <%= new Date(app.created_at).toLocaleDateString() %></small></p>
        </div>
        
        <div class="app-preview">
            <div class="preview-toolbar">
                <button class="fullscreen-btn" id="fullscreenBtn">⛶ Fullscreen</button>
            </div>
            <div id="previewContainer">
                <div class="preview-error" id="loadingPreview">
                    <h3>🔄 Loading your app...</h3>
                </div>
            </div>
        </div>
        
        <div class="app-info">
            <p><%= app.description || "No description provided." %></p>
            
            <div class="vote-section">
                <button class="vote-btn" onclick="vote(1)">👍 Upvote</button>
                <button class="vote-btn" onclick="vote(-1)">👎 Downvote</button>
                <span class="vote-count" id="voteCount">⭐ <%= app.votes || 0 %> points</span>
            </div>
            
            <% if (user && user.id === app.user_id) { %>
                <form action="/apps/delete/<%= app.id %>" method="POST" onsubmit="return confirm('Delete this app forever?');" style="display: inline;">
                    <button type="submit" class="delete-btn">🗑️ Delete App</button>
                </form>
            <% } %>
            
            <div class="comments-section">
                <h3>💬 Comments</h3>
                <% if (user) { %>
                    <form action="/apps/comment/<%= app.id %>" method="POST">
                        <textarea name="content" rows="3" placeholder="Share your thoughts..."></textarea>
                        <button type="submit">Post Comment</button>
                    </form>
                <% } else { %>
                    <p><a href="/auth/login">Login</a> to comment.</p>
                <% } %>
                
                <div style="margin-top: 1rem;">
                    <% if (comments && comments.length > 0) { %>
                        <% comments.forEach(comment => { %>
                            <div class="comment">
                                <strong><%= comment.username %></strong>
                                <p><%= comment.content %></p>
                                <small><%= new Date(comment.created_at).toLocaleString() %></small>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <p>No comments yet. Be the first!</p>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
    <div style="text-align: center; margin-top: 1rem;">
        <a href="/" class="back-btn">← Back to Home</a>
        <a href="/users/profile/<%= app.user_id %>" class="back-btn">👤 Developer Profile</a>
    </div>

    <script>
        let iframe = null;
        const previewContainer = document.getElementById('previewContainer');
        const appPath = '/<%= app.folder_path %>';
        
        // Load the app preview
        fetch(appPath + '/index.html')
            .then(response => {
                if (response.ok) {
                    previewContainer.innerHTML = `<iframe src="${appPath}/index.html" class="preview-frame" id="appIframe" sandbox="allow-same-origin allow-scripts allow-popups allow-forms allow-modals"></iframe>`;
                    iframe = document.getElementById('appIframe');
                } else {
                    throw new Error('index.html not found');
                }
            })
            .catch(() => {
                previewContainer.innerHTML = `
                    <div class="preview-error">
                        <h3>⚠️ Preview Unavailable</h3>
                        <p>No index.html found in the uploaded folder.</p>
                        <p>Make sure your app folder contains an index.html file.</p>
                    </div>
                `;
            });
        
        // Fullscreen functionality
        const fullscreenBtn = document.getElementById('fullscreenBtn');
        
        function toggleFullscreen() {
            if (!iframe) {
                iframe = document.getElementById('appIframe');
                if (!iframe) return;
            }
            if (iframe.requestFullscreen) {
                iframe.requestFullscreen();
            } else if (iframe.webkitRequestFullscreen) { /* Safari */
                iframe.webkitRequestFullscreen();
            } else if (iframe.msRequestFullscreen) { /* IE/Edge */
                iframe.msRequestFullscreen();
            }
        }
        
        fullscreenBtn.addEventListener('click', toggleFullscreen);
        
        // Vote function
        function vote(value) {
            fetch('/apps/vote/<%= app.id %>', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ value: value })
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) location.reload();
                else if (data.error === 'Login required') alert('Please login to vote!');
                else alert('Error voting.');
            });
        }
    </script>
</body>
</html>